# FloodGuardian environment configuration
# Copy to .env and adjust as needed.
# All variables must be prefixed with FLOODGUARDIAN_ to avoid system env collisions.

# App
FLOODGUARDIAN_APP_NAME=FloodGuardian
FLOODGUARDIAN_DEBUG=true

# Database (SQLite for hackathon portability; swap for postgres in prod)
FLOODGUARDIAN_DATABASE_URL=sqlite:///./floodguardian.db

# Redis (optional - leave blank to use in-memory pub/sub)
# FLOODGUARDIAN_REDIS_URL=redis://localhost:6379/0
FLOODGUARDIAN_USE_REDIS=false

# OSMnx / Map
FLOODGUARDIAN_DEFAULT_PLACE=Mangalore, Karnataka, India
FLOODGUARDIAN_DEFAULT_NETWORK_TYPE=drive
FLOODGUARDIAN_DEFAULT_GRAPH_CACHE=./cache/road_graph.graphml
FLOODGUARDIAN_DEFAULT_BBOX_STR=12.8600,74.7800,12.9600,74.9200

# Routing
FLOODGUARDIAN_ROUTE_PROFILE_DEFAULT=fastest
FLOODGUARDIAN_REROUTE_THRESHOLD_RISK=0.6
FLOODGUARDIAN_MAX_ALTERNATIVES=2

# Validation weights (must sum to 1.0) - photo_geo removed
FLOODGUARDIAN_VALIDATION_WEIGHTS={"traffic_anomaly":0.40,"rainfall":0.30,"historical_flood":0.20,"water_proximity":0.10}
FLOODGUARDIAN_REPORT_ACCEPT_THRESHOLD=0.40

# Flood Intelligence
FLOODGUARDIAN_RISK_DECAY_PER_HOUR=0.15
FLOODGUARDIAN_RISK_DEPTH_MULTIPLIER={"none":0.0,"ankle":0.45,"knee":0.7,"waist":0.85,"chest":0.95,"above_chest":1.0}

# CORS
FLOODGUARDIAN_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]
